# ============================================
# SentinelMAS — Environment Variables
# ============================================
# Copy this file to .env.local and fill in the values you need.
#   cp .env.example .env.local

# ------ Disaster Data APIs ------

# NASA FIRMS (fire detection) - get free key at https://firms.modaps.eosdis.nasa.gov/api/
FIRMS_MAP_KEY=

# GDACS API (optional, public API available without key)
GDACS_API_KEY=

# NOAA Weather API (free, no key required for basic use)
# NOAA_API_BASE=https://api.weather.gov

# ------ AI Agents ------

# Anthropic API (Claude) for AI agent reasoning
ANTHROPIC_API_KEY=

# OpenAI (optional fallback)
OPENAI_API_KEY=

# ------ Backend ------

# Port for the Python FastAPI backend (default: 8000)
API_PORT=8000

# ------ Frontend ------

# Vite dev server port (default: 3000)
VITE_PORT=3000
